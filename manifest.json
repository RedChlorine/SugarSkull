{
    "manifest_version": 3,
    "name": "SugarSkull",
    "version": "0.5",
    "description": "A Chromium extension that enables UNISA students to customise the appearance of their myUNISA portal.",
    "icons": {
        "16": "SugarSkull_Icons/SugarSkull_Icon_16.png",
        "48": "SugarSkull_Icons/SugarSkull_Icon_48.png",
        "128": "SugarSkull_Icons/SugarSkull_Icon_128.png"
    },
    "action": {
        "default_icon": {
            "16": "SugarSkull_Icons/SugarSkull_Icon_16.png",
            "48": "SugarSkull_Icons/SugarSkull_Icon_48.png",
            "128": "SugarSkull_Icons/SugarSkull_Icon_128.png"
        },
        "default_title": "SugarSkull"
    },
    "permissions": ["storage"],
    "content_scripts": [
        {
            "matches": ["*://mymodules.dtls.unisa.ac.za/*"],
            "css": ["sugar-styles.css"]
        }
    ]
}